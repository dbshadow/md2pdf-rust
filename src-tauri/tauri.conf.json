{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "md2pdf",
  "version": "1.0.2",
  "identifier": "com.tauri.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite-dev",
    "beforeBuildCommand": "npm run vite-build"
  },
  "app": {
    "windows": [
      {
        "title": "md2pdf - Markdown to PDF",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
